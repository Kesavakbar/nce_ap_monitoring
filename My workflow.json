    {
      "parameters": {
        "jsCode": "// Mengambil teks JSON mentah hasil pembacaan Gemini\nconst rawText = $input.all()[0].json.content.parts[0].text;\n\n// Mengubah teks string menjadi objek Array JavaScript resmi\nconst apArray = JSON.parse(rawText);\n\n// Mengembalikan data ke format yang dipahami oleh node Google Sheets n8n\nreturn apArray.map(ap => {\n  return {\n    json: {\n      ap_name: ap.ap_name,\n      rssi_dbm: ap.rssi_dbm,\n      cu_percent: ap.cu_percent,\n      access_user: ap.access_user,\n      ap_status: ap.ap_status\n    }\n  };\n});\n"
